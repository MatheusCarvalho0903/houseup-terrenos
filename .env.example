# Supabase — Project Settings → API
# URL do projeto (ex.: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (anon) — segura para uso no browser, protegida por RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (service_role) — NUNCA exponha no client.
# Usada apenas em Server Actions para a Admin API (convidar usuários).
SUPABASE_SERVICE_ROLE_KEY=
